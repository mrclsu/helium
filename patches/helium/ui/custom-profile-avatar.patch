+std::optional<gfx::Image> DecodeAndCropAvatar(std::string data_url) {
+  // Data URL format: "data:<mime>;base64,<data>"
+  const std::string base64_prefix = ";base64,";
+  size_t prefix_pos = data_url.find(base64_prefix);
+  if (prefix_pos == std::string::npos) {
+    return {};
+  }
+
+  const std::string mime_part = data_url.substr(5, prefix_pos - 5);
+  const std::string base64_data =
+      data_url.substr(prefix_pos + base64_prefix.size());
+
+  std::string decoded;
+  if (!base::Base64Decode(base64_data, &decoded)) {
+    return {};
+  }
+
+  const auto* bytes = reinterpret_cast<const uint8_t*>(decoded.data());
+  const size_t byte_count = decoded.size();
+
+  SkBitmap bitmap;
+  if (mime_part == "image/png") {
+    bitmap =
+        gfx::PNGCodec::Decode(base::span<const uint8_t>(bytes, byte_count));
+  } else if (mime_part == "image/jpeg" || mime_part == "image/jpg") {
+    bitmap =
+        gfx::JPEGCodec::Decode(base::span<const uint8_t>(bytes, byte_count));
+  } else {
+    return {};
+  }
+
+  if (bitmap.isNull() || bitmap.empty()) {
+    return {};
+  }
+
+  constexpr int kCustomAvatarSize = 256;
+  gfx::ImageSkia image_skia = gfx::ImageSkia::CreateFrom1xBitmap(bitmap);
+  gfx::ImageSkia image_cropped =
+      gfx::ImageSkiaOperations::CreateCroppedCenteredRoundRectImage(
+          gfx::Size(kCustomAvatarSize, kCustomAvatarSize), 0, image_skia);
+  if (image_cropped.isNull()) {
+    return {};
+  }
+
+  bitmap = *image_cropped.bitmap();
+
+  return gfx::Image::CreateFrom1xBitmap(bitmap);
+}
+
